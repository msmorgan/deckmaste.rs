// Static: red creatures get +1/+1 (layer 7c, scope filters on derived color).
Normal(
    name: "Red anthem",
    mana_cost: [Generic(1), Red],
    types: [Enchantment],
    abilities: [
        Static(effects: [
            Modify(of: Matching(ColorIs(Red)), changes: [AddPower(1), AddToughness(1)]),
        ]),
    ],
)
