// {B} 1/1: whenever a creature dies, controller loses 1 life.
// modeled on Blood Artist / Vindictive Vampire.
Normal(
    name: "Creature dies-watcher LoseLife",
    mana_cost: [Black],
    types: [Creature],
    power: 1,
    toughness: 1,
    abilities: [
        Triggered(
            event: Dies(Type(Creature)),
            effect: LoseLife(1),
        ),
    ],
)
