// {1}{U} 1/1: when this enters the battlefield, draw 1 card.
// modeled on Elvish Visionary.
Normal(
    name: "Creature etb-trigger DrawCards",
    mana_cost: [Generic(1), Blue],
    types: [Creature],
    power: 1,
    toughness: 1,
    abilities: [
        Triggered(
            event: Enters(Is(This)),
            effect: DrawCards(1),
        ),
    ],
)
