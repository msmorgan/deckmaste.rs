// A static enchantment: all creatures get +1/+1 (layer 7c).
Normal(
    name: "Anthem",
    mana_cost: [Generic(1), White],
    types: [Enchantment],
    abilities: [
        Static(effects: [
            Modify(of: Matching(Type(Creature)), changes: [AddPower(1), AddToughness(1)]),
        ]),
    ],
)
