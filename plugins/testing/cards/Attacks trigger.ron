// 2/2: whenever ~ attacks, its controller loses 1 life.
// proof fixture for the "becomes attacking" trigger seam ([CR#508.1a]).
Normal(
    name: "Attacks trigger",
    mana_cost: [Generic(1), Green],
    types: [Creature],
    power: 2,
    toughness: 2,
    abilities: [
        Triggered(
            event: StateBecomes(of: Is(This), becomes: Attacking),
            effect: LoseLife(1),
        ),
    ],
)
