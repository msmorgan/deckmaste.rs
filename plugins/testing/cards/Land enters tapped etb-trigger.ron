// A tapland with an enter trigger. Proves the collapsed land-play path reaches
// both new stages: it enters tapped (replace stage, via AsEnters) and fires its
// own enter trigger (trigger stage, via ZoneMove{to: Battlefield}). Modeled on
// Highland Forest (the tapland half) + an Enters trigger.
Normal(
    name: "Land enters tapped etb-trigger",
    types: [Land],
    abilities: [
        Static(effects: [
            Replacement(AsEnters(Tap(This))),
        ]),
        Triggered(
            event: Enters(Is(This)),
            effect: LoseLife(1),
        ),
    ],
)
