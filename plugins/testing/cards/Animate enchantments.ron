// Each enchantment becomes (only) a 4/4 creature: CardTypes(Set) replaces the
// type (L4) so it's no longer an Enchantment; Power/Toughness(Set) set P/T (L7b).
// The L7b set rides the L4-locked target set ([CR#613.6]).
Normal(
    name: "Animate enchantments",
    mana_cost: [Generic(4), White],
    types: [Enchantment],
    abilities: [
        Static(effects: [
            Modify(of: Matching(AllOf([Permanent, Type(Enchantment)])), changes: [
                CardTypes(Set([Creature])), Power(Set(4)), Toughness(Set(4)),
            ]),
        ]),
    ],
)
