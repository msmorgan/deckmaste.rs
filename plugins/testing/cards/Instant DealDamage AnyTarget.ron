// {R} instant, deals 3 to any target — fake removal used to kill fixtures.
// modeled on Lightning Bolt.
Normal(
    name: "Instant DealDamage AnyTarget",
    mana_cost: [Red],
    types: [Instant],
    abilities: [
        Spell(
            targets: [AnyTarget],
            effect: DealDamage(Target(0), 3),
        ),
    ],
)
