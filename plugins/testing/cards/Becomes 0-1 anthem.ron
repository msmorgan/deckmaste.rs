// All creatures have base P/T 0/1 (7b) and get +1/+1 (7c) — proves 7b-before-7c.
Normal(
    name: "Becomes 0-1 anthem",
    mana_cost: [Generic(2), Blue],
    types: [Enchantment],
    abilities: [
        Static(effects: [
            Modify(of: Matching(Type(Creature)), changes: [
                SetPower(0), SetToughness(1), AddPower(1), AddToughness(1),
            ]),
        ]),
    ],
)
