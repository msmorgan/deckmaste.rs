// Equipment ([CR#205.3g], [CR#301.5]) — an artifact subtype that can be
// attached only to a creature. The host restriction is a rule of the SUBTYPE,
// not a removable card ability, so it is conferred `Innate`: it survives "loses
// all abilities" while `attachment_legal` reads the `Cant(Attach)` generically
// (no engine subtype branch). The equip ACTIVATED ability rides the Equip
// keyword, not the subtype.
//
// Authored directly as a `Subtype` (not via the `ArtifactType` meta-macro)
// because this artifact subtype carries a `confers:` list.
(
    name: "Equipment",
    kinds: [Subtype],
    body: Subtype(
        name: "Equipment",
        types: [Artifact],
        confers: [
            Ability(Innate(Static(effects: [
                Cant(Attach(what: Ref(This), to: Not(Type(Creature)))),
            ]))),
        ],
    ),
)
