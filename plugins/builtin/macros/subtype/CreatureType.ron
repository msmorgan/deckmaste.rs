// [CR#205.3m]
(
    name: "CreatureType",
    kinds: [Macro],
    params: { "name": String, "template": String },
    body: (
        name: Param(name),
        template: Param(template),
        kinds: [Subtype],
        body: Subtype(
            name: Param(template),
            types: [Creature, Kindred],
        ),
    ),
)
