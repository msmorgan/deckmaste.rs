// [CR#205.3k]
(
    name: "SpellType",
    kinds: [Macro],
    params: { "name": String, "template": String },
    body: (
        name: Param(name),
        template: Param(template),
        kinds: [Subtype],
        body: Subtype(
            name: Param(template),
            types: [Instant, Sorcery],
        ),
    ),
)
