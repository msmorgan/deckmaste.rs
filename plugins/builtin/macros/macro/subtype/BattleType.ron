// [CR#205.3q]
(
    name: "BattleType",
    kinds: [Macro],
    params: { "name": String, "template": Default(String, Param(name)) },
    body: (
        name: Param(name),
        template: Param(template),
        kinds: [Subtype],
        body: Subtype(
            name: Param(template),
            types: [Battle],
        ),
    ),
)
