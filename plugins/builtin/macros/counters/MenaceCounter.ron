// A menace counter ([CR#122.1b]): its bearer gains menace at layer 6
// ([CR#613.1f]) — the FlyingCounter pattern with a different keyword.
(
    name: "MenaceCounter",
    template: "menace counter",
    kinds: [Counter],
    body: Counter(
        name: "MenaceCounter",
        confers: [
            Continuous(
                of: Of(This),
                changes: [GainAbility(Keyword(Menace))],
            ),
        ],
    ),
)
