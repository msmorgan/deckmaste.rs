// A hexproof counter ([CR#122.1b]): its bearer gains hexproof at layer 6
// ([CR#613.1f]) — the FlyingCounter pattern with a different keyword.
(
    name: "HexproofCounter",
    template: "hexproof counter",
    kinds: [Counter],
    body: Counter(
        name: "HexproofCounter",
        confers: [
            Continuous(
                of: Of(This),
                changes: [GainAbility(Keyword(Hexproof()))],
            ),
        ],
    ),
)
