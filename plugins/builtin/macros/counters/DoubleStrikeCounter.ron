// A double strike counter ([CR#122.1b]): its bearer gains double strike at layer 6
// ([CR#613.1f]) — the FlyingCounter pattern with a different keyword.
(
    name: "DoubleStrikeCounter",
    template: "double strike counter",
    kinds: [Counter],
    body: Counter(
        name: "DoubleStrikeCounter",
        confers: [
            Continuous(
                of: Of(This),
                changes: [GainAbility(Keyword(DoubleStrike))],
            ),
        ],
    ),
)
