// A haste counter ([CR#122.1b]): its bearer gains haste at layer 6
// ([CR#613.1f]) — the FlyingCounter pattern with a different keyword.
(
    name: "HasteCounter",
    template: "haste counter",
    kinds: [Counter],
    body: Counter(
        name: "HasteCounter",
        confers: [
            Continuous(
                of: Of(This),
                changes: [GainAbility(Keyword(Haste))],
            ),
        ],
    ),
)
