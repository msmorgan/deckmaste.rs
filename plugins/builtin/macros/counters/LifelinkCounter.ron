// A lifelink counter ([CR#122.1b]): its bearer gains lifelink at layer 6
// ([CR#613.1f]) — the FlyingCounter pattern with a different keyword.
(
    name: "LifelinkCounter",
    template: "lifelink counter",
    kinds: [Counter],
    body: Counter(
        name: "LifelinkCounter",
        confers: [
            Continuous(
                of: Of(This),
                changes: [GainAbility(Keyword(Lifelink))],
            ),
        ],
    ),
)
