// "AsEnters" = a self-replacement applied as the permanent enters the
// battlefield ([CR#614.1c,614.12]): an augment whose event is this object's own
// entry. Usage: AsEnters(effect) — e.g. AsEnters(Tap(This)) (enters tapped).
(
    name: "AsEnters",
    template: "as ~ enters",
    kinds: [Replacement],
    params: [Any],
    body: Also(would: ThisEnters, also: Param(0)),
)
