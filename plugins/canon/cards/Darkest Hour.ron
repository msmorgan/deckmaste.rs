// Hand-written ability: static prose is beyond the parsers today
// ("All creatures are black.").
Normal(
  name: "Darkest Hour",
  mana_cost: [
    Black,
  ],
  types: [
    Enchantment,
  ],
  abilities: [
    Static(effects: [
      Modify(of: Matching(Creature), changes: [SetColors([Black])]),
    ]),
  ],
)
