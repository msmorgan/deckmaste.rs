// Hand-written ability: the becomes-target event shape is beyond the
// triggered-ability parser today ("When ~ becomes the target of a spell
// or ability, sacrifice it.").
Normal(
    name: "Phantasmal Bear",
    mana_cost: [Blue],
    types: [Creature],
    subtypes: [
        Bear,
        Illusion,
    ],
    abilities: [
        Triggered(
            event: BecomesTarget(what: Ref(This)),
            effect: Sacrifice(This),
        ),
    ],
    power: 2,
    toughness: 2,
)
