Normal(
  name: "Pyroclasm",
  mana_cost: [
    Generic(1),
    Red,
  ],
  types: [
    Sorcery,
  ],
  abilities: [
    Spell(
      // "deals 2 damage to each creature" — the verb takes a single
      // `Reference` now, so plurality is the `Each` iterator binding each
      // creature as `It`; `Each` emits a simultaneous batch
      // ([CR#608,700.1]).
      effect: Each(binder: Existing(Filter(Creature)), effect: DealDamage(It, 2)),
    ),
  ],
)
