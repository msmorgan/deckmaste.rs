# Make plain `cargo fmt` use the nightly rustfmt binary so the nightly-only
# options in rustfmt.toml apply without `cargo +nightly fmt`. This only
# redirects the formatter -- the default build/test toolchain stays stable,
# so we avoid a rust-toolchain.toml nightly pin. The path is resolved per
# machine, so this works anywhere `rustup`'s nightly toolchain is installed.
#
# cargo's `.cargo/config.toml` [env] table is NOT honored by the external
# `cargo-fmt` subcommand, which is why this lives in direnv instead.
#
# Requires direnv + a shell hook; run `direnv allow` once after editing.
export RUSTFMT="$(rustup which --toolchain nightly rustfmt)"
